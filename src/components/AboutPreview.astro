---
import SectionDivider from "./SectionDivider.astro";
import Button from "./Button.astro";
---

<section class="about-preview">
  <div class="about-container">
    <div class="about-text">

      <div class="about-copy">
        <p class="eyebrow">Meet Mindy</p>

        <div class="divider-wrap">
          <SectionDivider />
        </div>

        <h2>
          Rooted in nursing experience, guided by classical homeopathy.
        </h2>

        <p>
          Mindy Wallent, founder of Divine Health Homeopathy, worked as a nurse
          for 14 years before her family's own health journey led her to discover
          classical homeopathy.
        </p>

        <p>
          Inspired by the profound changes she witnessed, she dedicated herself
          to studying this gentle, individualized system of medicine so she could
          help others discover a natural path toward lasting health.
        </p>

        <p>
          She is currently completing her clinical internship as a supervised
          student practitioner through Homeopathy Help Network, providing
          individualized classical homeopathic consultations under experienced
          supervision.
        </p>

        <div class="about-button">
          <Button href="/about" variant="gold">
            Learn More About Mindy
          </Button>
        </div>
      </div>
    </div>

    <div class="about-photo-wrap">
      <img
        src="/images/mindy-headshot.jpg"
        alt="Mindy Wallent"
        class="about-photo"
      />
    </div>
  </div>
</section>

<style>
  .about-preview {
    position: relative;
    overflow: hidden;
    background:
      radial-gradient(
        circle at top left,
        #fffaf0 0%,
        var(--cream) 55%,
        #efe4d3 100%
      );
    padding: 110px 40px;
  }

  .about-container {
    position: relative;
    z-index: 1;
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    gap: 80px;
    align-items: center;
  }

  .about-text {
    position: relative;
    max-width: 700px;
    isolation: isolate;
  }

  .about-copy {
    position: relative;
    z-index: 2;
  }

  .eyebrow {
    color: var(--gold);
    text-transform: uppercase;
    letter-spacing: 8px;
    font-size: 0.95rem;
    font-weight: 700;
    margin: 0 0 8px;
  }

  .divider-wrap {
    width: max-content;
    margin-bottom: 30px;
  }

  h2 {
    color: var(--navy);
    font-size: 3.1rem;
    line-height: 1.1;
    margin: 0 0 28px;
  }

  p {
    color: #34445f;
    font-size: 1.15rem;
    line-height: 1.85;
    margin: 0 0 26px;
  }

  .about-button {
    margin-top: 34px;
  }

  .about-photo-wrap {
    max-width: 325px;
    justify-self: center;
    background: var(--vanilla);
    border: 1px solid #e2d5bf;
    border-radius: 34px;
    padding: 10px;
    box-shadow: 0 28px 70px rgba(16, 35, 63, 0.18);
  }

  .about-photo {
    display: block;
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    object-position: center;
    border-radius: 26px;
  }

  @media (max-width: 900px) {
    .about-preview {
      padding: 85px 24px;
    }

    .about-container {
      grid-template-columns: 1fr;
      gap: 50px;
    }

    .about-text {
      max-width: none;
    }

    .eyebrow {
      text-align: center;
    }

    .divider-wrap {
      margin-left: auto;
      margin-right: auto;
    }

    h2 {
      font-size: 2.4rem;
      text-align: center;
    }

    .about-button {
      display: flex;
      justify-content: center;
    }

    .about-photo-wrap {
      max-width: 420px;
      margin: 0 auto;
    }
  }
</style>