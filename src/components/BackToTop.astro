<button
  id="back-to-top"
  class="back-to-top"
  type="button"
  aria-label="Return to top of page"
>
  <img
    src="/images/dhh-fleur-official.png"
    alt=""
    aria-hidden="true"
  />
</button>

<script>
  const backToTopButton = document.querySelector<HTMLButtonElement>(
    "#back-to-top"
  );

  if (backToTopButton) {
    const updateVisibility = () => {
      const shouldShow = window.scrollY > 550;

      backToTopButton.classList.toggle("is-visible", shouldShow);
    };

    updateVisibility();

    window.addEventListener("scroll", updateVisibility, {
      passive: true,
    });

    backToTopButton.addEventListener("click", () => {
      const prefersReducedMotion = window.matchMedia(
        "(prefers-reduced-motion: reduce)"
      ).matches;

      window.scrollTo({
        top: 0,
        behavior: prefersReducedMotion ? "auto" : "smooth",
      });
    });
  }
</script>

<style>
  .back-to-top {
    position: fixed;
    right: 2rem;
    bottom: 2rem;
    z-index: 50;

    display: grid;
    width: 56px;
    height: 56px;
    place-items: center;

    padding: 0;
    border: 1px solid #c7a35a;
    border-radius: 50%;
    background: #fbf7ef;
    box-shadow:
      0 8px 22px rgba(15, 42, 77, 0.14),
      0 2px 6px rgba(15, 42, 77, 0.08);

    cursor: pointer;

    opacity: 0;
    visibility: hidden;
    pointer-events: none;

    transform: translateY(10px) scale(0.96);

    transition:
      opacity 280ms ease,
      visibility 280ms ease,
      transform 280ms ease,
      box-shadow 220ms ease;
  }

  .back-to-top.is-visible {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transform: translateY(0) scale(1);
  }

  .back-to-top img {
    display: block;
    width: 31px;
    height: 31px;
    object-fit: contain;

    transition: transform 220ms ease;
  }

  .back-to-top:hover {
    transform: translateY(-2px) scale(1);
    box-shadow:
      0 12px 28px rgba(15, 42, 77, 0.18),
      0 4px 10px rgba(15, 42, 77, 0.1);
  }

  .back-to-top:hover img {
    transform: rotate(-6deg) scale(1.04);
  }

  .back-to-top:focus-visible {
    outline: 3px solid rgba(199, 163, 90, 0.65);
    outline-offset: 4px;
  }

  .back-to-top:active {
    transform: translateY(0) scale(0.98);
  }

  @media (max-width: 900px) {
    .back-to-top {
      right: 1.5rem;
      bottom: 1.5rem;
      width: 52px;
      height: 52px;
    }

    .back-to-top img {
      width: 29px;
      height: 29px;
    }
  }

  @media (max-width: 600px) {
    .back-to-top {
      right: 1rem;
      bottom: calc(1rem + env(safe-area-inset-bottom));
      width: 48px;
      height: 48px;
    }

    .back-to-top img {
      width: 26px;
      height: 26px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .back-to-top,
    .back-to-top img {
      transition-duration: 0.01ms;
    }
  }
</style>