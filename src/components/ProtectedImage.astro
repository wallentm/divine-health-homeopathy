---
interface Props {
  src: string;
  alt: string;
  width?: number;
  height?: number;
  class?: string;
  loading?: "lazy" | "eager";
  objectFit?: "cover" | "contain";
  objectPosition?: string;
}

const {
  src,
  alt,
  width,
  height,
  class: className = "",
  loading = "lazy",
  objectFit = "cover",
  objectPosition = "center",
} = Astro.props;
---

<div
  class:list={["protected-image", className]}
  data-protected-image
  style={`--image-fit: ${objectFit}; --image-position: ${objectPosition};`}
>
  <img
    src={src}
    alt={alt}
    width={width}
    height={height}
    loading={loading}
    decoding="async"
    draggable="false"
  />

  <span class="protected-image-overlay" aria-hidden="true"></span>
</div>

<script>
  function protectImages() {
    const protectedImages = document.querySelectorAll(
      "[data-protected-image]"
    );

    protectedImages.forEach((container) => {
      if (container.hasAttribute("data-protection-active")) return;

      container.setAttribute("data-protection-active", "true");

      container.addEventListener("contextmenu", (event) => {
        event.preventDefault();
      });

      container.addEventListener("dragstart", (event) => {
        event.preventDefault();
      });
    });
  }

  protectImages();

  document.addEventListener("astro:page-load", protectImages);
</script>

<style>
  .protected-image {
    position: relative;
    display: block;
    overflow: hidden;
    -webkit-user-select: none;
    user-select: none;
    -webkit-touch-callout: none;
  }

  .protected-image img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: var(--image-fit);
    object-position: var(--image-position);
    pointer-events: none;
    -webkit-user-drag: none;
    user-select: none;
  }

  .protected-image-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    display: block;
    background: transparent;
  }
</style>