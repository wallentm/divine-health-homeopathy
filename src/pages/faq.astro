    font-weight: 700;
    letter-spacing: 0.34em;
    text-transform: uppercase;
  }

  h1,
  h2,
  h3 {
    color: var(--navy);
  }

  h1 {
    margin: 0;

    font-size: clamp(3.5rem, 6vw, 5.8rem);
    line-height: 0.98;
  }

  h2 {
    margin: 0;

    font-size: clamp(2.65rem, 4.7vw, 4rem);
    line-height: 1.06;
  }

  cite {
    font-style: italic;
  }

  .divider-left {
    width: max-content;
    margin-top: 24px;
  }

  /*
   * Historical hero
   */

  .faq-hero {
    padding: 72px 40px 78px;

    background:
      radial-gradient(
        circle at top right,
        #fffdf8 0%,
        #f5ead9 58%,
        #ead9c1 100%
      );
  }

  .faq-hero-inner {
    max-width: 1180px;
    margin: 0 auto;

    display: grid;
    grid-template-columns: 0.82fr 1.18fr;
    gap: 68px;
    align-items: center;
  }

  .letter-figure {
    margin: 0;
  }

  .letter-frame {
    padding: 12px;

    background: #f8efdf;
    border: 1px solid #d7c29f;

    box-shadow:
      0 24px 58px rgba(16, 35, 63, 0.13);

    transform: rotate(-1deg);
  }

  .letter-frame .protected-image {
    display: block;

    width: 100%;
    height: auto;
    max-height: 610px;
}

.letter-frame .protected-image img {
    width: 100%;
    height: auto;

    object-fit: contain;
    object-position: center;

    filter:
      sepia(0.08)
      saturate(0.86)
      contrast(0.98);
}

  .letter-figure figcaption {
    margin-top: 14px;

