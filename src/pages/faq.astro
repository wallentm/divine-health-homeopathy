  }

  .hero-divider {
    width: max-content;
    margin: 24px 0;
  }

  .hero-copy blockquote {
    margin: 25px 0;
    padding-left: 25px;

    border-left: 3px solid var(--gold);
  }

  .hero-copy blockquote p {
    margin: 0;

    color: var(--navy);
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(1.75rem, 3.1vw, 2.65rem);
    font-style: italic;
    line-height: 1.36;
  }

  .hero-copy blockquote cite {
    display: block;
    margin-top: 12px;

    color: #756b5c;
    font-size: 0.95rem;
    font-style: normal;
  }

  .hero-intro {
    max-width: 650px;
    margin: 0;

    color: #40516a;
    font-size: 1.15rem;
    line-height: 1.82;
  }

  /*
   * Shared FAQ topic sections
   */

