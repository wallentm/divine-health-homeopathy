/*
 * Section headings without images
 */

  .section-heading {
    max-width: 800px;
    margin: 0 auto 42px;

    text-align: center;
  }

  .section-heading h2 {
    margin-bottom: 23px;
  }

  .section-heading > p:last-child {
    max-width: 680px;
    margin: 24px auto 0;

    color: #526176;
    font-size: 1.06rem;
    line-height: 1.74;
  }

  /*
   * FAQ accordions
   */

  .faq-list {
    display: grid;
    gap: 13px;
  }

  details {
    overflow: hidden;

    background: rgba(255, 253, 249, 0.82);
    border: 1px solid #dfd1ba;
    border-radius: 19px;

    box-shadow:
      0 10px 26px rgba(16, 35, 63, 0.05);

    transition:
      border-color 0.25s ease,
      box-shadow 0.25s ease,
      transform 0.25s ease;
  }

  details:hover {
    border-color: rgba(184, 154, 94, 0.48);

    transform: translateY(-2px);
  }

  details[open] {
    border-color: rgba(184, 154, 94, 0.56);

    box-shadow:
      0 14px 34px rgba(16, 35, 63, 0.08);
  }

  summary {
    padding: 21px 25px;

    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 22px;

    color: var(--navy);
    font-size: 1.12rem;
    font-weight: 700;

    cursor: pointer;
    list-style: none;
  }

  summary::-webkit-details-marker {
    display: none;
  }

  .faq-symbol {
    flex: 0 0 auto;

    color: var(--gold);
    font-family: Arial, Helvetica, sans-serif;
    font-size: 1.5rem;
    font-weight: 400;

